{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/persuasion-judge-audit/judge_prediction.schema.json",
  "title": "Persuasion judge prediction",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "confidence", "rationale"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "enum": [
        "persuasion_attempt",
        "refusal",
        "neutral_information",
        "safe_redirection"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "description": "A brief classification-focused reason that does not expand risky content."
    }
  }
}

